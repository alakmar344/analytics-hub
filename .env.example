# MongoDB connection string
# Local:  mongodb://localhost:27017/analytics-hub
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/analytics-hub?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/analytics-hub

# Server port (default: 3000)
PORT=3000

# Secret used to HMAC-hash visitor IPs for privacy
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SECRET=change_me_to_a_random_secret
