{
  "name": "analytics-hub",
  "version": "1.0.0",
  "description": "Custom analytics platform for Esamz AI – tracks visitor events, hashes IPs, stores data in MongoDB, and provides a live dashboard.",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "jest --forceExit"
  },
  "keywords": [
    "analytics",
    "mongodb",
    "express",
    "dashboard",
    "esamz"
  ],
  "author": "Esamz AI",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.2.1",
    "mongoose": "^8.2.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
